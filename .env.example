# Copy to ".env" and set your values. Never commit .env (it is gitignored).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: ECO assistant (Gemini chat)
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=

# Optional: waste scan — Google Cloud Vision API (Label Detection)
# VITE_GOOGLE_VISION_API_KEY=

# Optional: reserved (map uses OpenStreetMap)
# VITE_GOOGLE_MAPS_API_KEY=
