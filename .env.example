# Copy to ".env" and set your values. Never commit .env (it is gitignored).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: EKO asistent (Gemini)
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=

# Optional: scan classification (Groq vision)
# VITE_GROQ_API_KEY=
# VITE_GROQ_VISION_MODEL=

# Optional: Google Maps basemap (Maps JavaScript API)
# VITE_GOOGLE_MAPS_API_KEY=
